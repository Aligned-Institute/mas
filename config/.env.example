# Huntsman Brief Generator — Environment Config
# Copy this file to .env and fill in your keys

# Required — Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Optional but recommended — unlocks FRED macro section (GDP, CPI, housing, rates)
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Optional — Connects Phase 3 interactive RAG search to Supabase (pgvector)
# Fallback: defaults to local JSON RAG store if left blank
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here

